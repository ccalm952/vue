// 用于在 Node 环境运行的配置文件（如 Vite 配置），与浏览器端 `tsconfig.app` 分离。
{
  "extends": "./node_modules/@tsconfig/node24/tsconfig.json",
  "include": [
    "vite.config.*",
    "vitest.config.*",
    "cypress.config.*",
    "playwright.config.*"
  ],
  "compilerOptions": {
    // 与 Vite 等打包工具一致，使用 bundler 解析方式。
    "module": "preserve",
    "moduleResolution": "bundler",

    // 仅引入 Node 类型，避免误把其它 `@types/*` 全局混进来。
    "types": ["node"],

    // 只作类型检查，此处不输出 JS。
    "noEmit": true,

    // 增量缓存，放在 node_modules 下。
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo"
  }
}
